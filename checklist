  function downloadExcel() {
    const name = document.getElementById('studentName').value.trim() || 'Student';
    const answers = getAnswers();
    const score = answers.reduce((sum, a) => sum + (a ? SCORE_MAP[a] : 0), 0);
    const maxScore = TOTAL * 2;

    const rows = [
      ["Zelfevaluatie – Campagne Assessment"],
      ["Naam", name],
      ["Datum", new Date().toLocaleDateString('nl-NL')],
      [],
      ["#", "Onderdeel", "Criterium", "Score", "Punten"],
    ];

    criteriaData.forEach((c, i) => {
      const ans = answers[i] || '—';
      const pts = answers[i] !== null ? SCORE_MAP[answers[i]] : '';
      rows.push([i + 1, c.section, c.text, ans, pts]);
    });

    rows.push([]);
    rows.push(["", "", "", "Totaalscore:", `${score} / ${maxScore}`]);
    rows.push(["", "", "", "Percentage:", `${Math.round((score / maxScore) * 100)}%`]);

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.aoa_to_sheet(rows);
    ws['!cols'] = [{ wch: 4 }, { wch: 28 }, { wch: 70 }, { wch: 30 }, { wch: 8 }];
    XLSX.utils.book_append_sheet(wb, ws, "Zelfevaluatie");
    XLSX.writeFile(wb, `zelfevaluatie_${name.replace(/\s+/g, '_')}.xlsx`);
  }
